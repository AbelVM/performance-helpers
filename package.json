{
  "name": "performance-helpers",
  "version": "1.0.1",
  "description": "Performance toolbox",
  "keywords": [
    "node",
    "javascript",
    "performance",
    "workers",
    "cache",
    "buffer",
    "logger",
    "pool",
    "batch",
    "eventbus",
    "microtask",
    "macrotask",
    "scheduler",
    "utilities",
    "helpers",
    "parallel",
    "concurrency",
    "throttle",
    "debounce",
    "memoize",
    "lru",
    "ttl"
  ],
  "homepage": "https://abelvm.github.io/performance-helpers/",
  "bugs": {
    "url": "https://github.com/AbelVM/performance-helpers/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbelVM/performance-helpers.git"
  },
  "license": "MIT",
  "author": "Abel Vázquez Montoro",
  "type": "module",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./src/index.js",
      "require": "./src/index.js",
      "default": "./src/index.js"
    },
    "./powerBackpressure": {
