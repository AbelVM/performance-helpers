{
  "name": "performance-helpers",
  "version": "1.0.0",
  "description": "Performance toolbox",
  "keywords": [
    "node",
    "javascript",
    "performance",
    "workers",
    "cache",
    "buffer",
    "logger",
    "pool",
    "batch",
    "eventbus",
    "microtask",
    "macrotask",
    "scheduler",
    "utilities",
    "helpers",
    "parallel",
    "concurrency",
    "throttle",
    "debounce",
    "memoize",
    "lru",
    "ttl"
  ],
  "homepage": "https://abelvm.github.io/performance-helpers/",
  "bugs": {
    "url": "https://github.com/AbelVM/performance-helpers/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbelVM/performance-helpers.git"
  },
  "license": "MIT",
  "author": "Abel Vázquez Montoro",
  "type": "module",
  "main": "src/index.js",
  "types": "types/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.js",
      "require": "./src/index.js",
      "default": "./src/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.js\" \"test/**/*.js\" \"bench/**/*.js\" \"scripts/**/*.js\"",
    "lint:fix": "eslint --fix \"src/**/*.js\" \"test/**/*.js\" \"bench/**/*.js\" \"scripts/**/*.js\"",
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.js\" \"bench/**/*.js\" \"scripts/**/*.js\" \"*.md\"",
    "test:coverage": "vitest run --coverage --reporter=verbose",
    "docs": "typedoc",
    "bench": "node bench/run.js",
    "bench:pool": "node bench/run.js pool",
    "bench:cache": "node bench/run.js cache",
    "types:generate": "tsc --project tsconfig.json --emitDeclarationOnly --declaration --allowJs --outDir types --declarationMap false",
    "build:full": "npm run lint:fix && npm run format && npm run types:generate && npm run bench && npm run build && npm run test && npm run docs"
  },
  "engines": {
    "node": ">=16"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/web-worker": "^4.1.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "terser": "^5.46.1",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^5.4.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
